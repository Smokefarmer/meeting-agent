# Skribby — meeting bot service (skribby.io)
SKRIBBY_API_KEY=

# ElevenLabs — text-to-speech (elevenlabs.io)
ELEVENLABS_API_KEY=

# Anthropic — intent extraction (anthropic.com)
ANTHROPIC_API_KEY=

# GitHub — issue creation (github.com)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Telegram — summary delivery (via OpenClaw config)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenClaw instance
OPENCLAW_INSTANCE_NAME=MeetingClaw

# Intent confidence threshold (0.0–1.0)
CONFIDENCE_THRESHOLD=0.85
